# Vercel Cron security. Vercel will send this as Authorization: Bearer <secret>.
CRON_SECRET="replace-with-a-random-32-char-secret"

# Public Ads Library scraping service.
# The app sends POST { url, pageId, pageName, activeStatus, limit } and accepts
# response arrays under ads, data, results, or items. For video ads, the scraper
# should return videoUrl/creativeMediaUrl or videoScript/transcript. For images,
# return imageUrl/creativeMediaUrl. Also return headline, body/caption, CTA text,
# CTA link, and ad snapshot URL when available.
SCRAPER_API_URL="https://your-scraper.example.com/facebook-ads-library"
SCRAPER_API_KEY="replace-if-your-scraper-needs-one"
SCRAPER_PROVIDER="generic"

# Optional: fixture mode for testing the Notion/OpenAI pipeline without scraping.
USE_FIXTURE_ADS="false"

# Notion integration. Share the database with your Notion integration first.
NOTION_API_KEY="secret_..."
NOTION_DATABASE_ID="5dbd19dce74e48e6912f389d93b952af"
NOTION_VERSION="2022-06-28"

# OpenAI idea generation.
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4.1-mini"

# Pipeline controls.
MAX_ADS_PER_COMPETITOR="3"
IDEAS_PER_AD="2"
DRY_RUN="false"
